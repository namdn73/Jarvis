# Jarvis — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Google Gemini — gemini-2.0-flash (free tier, 1500 req/day)
# Get yours at: aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily — web search API (free tier, 1000 req/month)
# Get yours at: tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Backend server settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Agent model (deepagents provider:model format)
MODEL_AGENT=google_genai:gemini-2.0-flash

# Whisper model size: tiny | base | small (base recommended for CPU)
WHISPER_MODEL=base

# TTS voice (edge-tts)
TTS_VOICE=en-GB-RyanNeural

# Wake word confidence threshold (0.0–1.0, lower = more sensitive)
WAKE_WORD_THRESHOLD=0.5

# Audio VAD thresholds (tune if Jarvis is too sensitive or not sensitive enough)
SPEECH_THRESHOLD=0.02
SILENCE_THRESHOLD=0.01
SILENCE_FRAMES=24

# State machine timeouts (seconds)
LISTEN_TIMEOUT_S=10
ACTIVE_WINDOW_S=30

# Session recall window in seconds (default: 7200 = 2 hours)
SESSION_RECALL_WINDOW=7200

# Paths (relative to project root, change only if you move folders)
PROMPTS_DIR=backend/prompts
AGENT_DATA_DIR=backend/agent_data
